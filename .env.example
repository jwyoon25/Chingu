# Chingu local demo secrets — TEMPLATE.
#
# Copy this file to `.env` (which is gitignored) and fill in your real keys:
#     cp .env.example .env
# Then run the app with:
#     ./scripts/run.sh
#
# Never commit `.env`. Never hardcode keys in source. These are read at runtime
# via ProcessInfo.processInfo.environment.

# Anthropic (Claude) — required for chat + web search (Checkpoint 1).
# Get one at https://console.anthropic.com/  → API keys.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# ElevenLabs — speech (Checkpoint 4, not yet wired up). Optional for CP1.
# Leave the placeholder or blank until you build speech.
ELEVENLABS_API_KEY=
